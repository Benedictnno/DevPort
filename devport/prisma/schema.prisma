// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String?
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id          String      @id @default(uuid())
  ownerId     String
  owner       User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  
  slug        String      @unique
  title       String
  summary     String      // Short description for cards/header
  overview    String      @db.Text // Full project description
  
  githubUrl   String?
  liveUrl     String?
  
  status      ProjectStatus @default(DRAFT)
  visibility  ProjectVisibility @default(PRIVATE)
  featured    Boolean     @default(false)
  
  media       Media[]
  techStacks  ProjectTechStack[]
  buildNotes  BuildNote[]
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([ownerId])
  @@index([slug])
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
}

enum ProjectVisibility {
  PUBLIC
  PRIVATE
}

// Separate Media model because a project can have multiple screenshots/videos
model Media {
  id          String    @id @default(uuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  url         String    // Cloudinary URL
  publicId    String    // Cloudinary Public ID for deletion/management
  type        MediaType @default(IMAGE)
  altText     String?
  order       Int       @default(0) // For displaying galleries in a specific order
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId])
}

enum MediaType {
  IMAGE
  VIDEO
}

// Centralized TechStack table to avoid duplicating technologies (e.g., React, Next.js)
model TechStack {
  id          String    @id @default(uuid())
  name        String    @unique // e.g., "React", "TypeScript"
  iconUrl     String?
  projects    ProjectTechStack[]
}

// Junction table for Many-to-Many relationship between Project and TechStack
model ProjectTechStack {
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  techStackId String
  techStack   TechStack @relation(fields: [techStackId], references: [id], onDelete: Cascade)

  @@id([projectId, techStackId])
}

// Separate BuildNote model as it represents distinct log entries or architecture decisions over time
model BuildNote {
  id          String    @id @default(uuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  title       String
  content     String    @db.Text
  date        DateTime  @default(now())
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId])
}
